# =============================================================================
# FiBuKI Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_* vars are exposed to the browser — never put secrets there.

# -----------------------------------------------------------------------------
# Firebase (client-side — get from Firebase Console > Project Settings)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Firebase (server-side — for Admin SDK in API routes)
# -----------------------------------------------------------------------------
# JSON string of a Firebase service account key (download from Firebase Console)
FIREBASE_SERVICE_ACCOUNT_KEY=

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Your production domain (used for CORS, email links, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloud Functions base URL (auto-derived from project ID if not set)
# NEXT_PUBLIC_FUNCTIONS_URL=https://europe-west1-YOUR_PROJECT.cloudfunctions.net

# -----------------------------------------------------------------------------
# Super Admin
# -----------------------------------------------------------------------------
# Email address that gets automatic admin privileges on first login
SUPER_ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# AI — Anthropic (Chat / Agent)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# AI — Google Vertex AI (extraction, column matching, partner lookup)
# Region for Vertex AI calls (default: europe-west1)
# VERTEX_LOCATION=europe-west1

# -----------------------------------------------------------------------------
# Stripe (Billing & Subscriptions)
# -----------------------------------------------------------------------------
# Set via Firebase secrets: firebase functions:secrets:set STRIPE_SECRET_KEY
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Banking — TrueLayer
# -----------------------------------------------------------------------------
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URL=http://localhost:3000/api/truelayer/callback
# Set to "true" to use TrueLayer sandbox
TRUELAYER_SANDBOX=true

# -----------------------------------------------------------------------------
# Banking — finAPI
# -----------------------------------------------------------------------------
FINAPI_CLIENT_ID=
FINAPI_CLIENT_SECRET=
FINAPI_ENVIRONMENT=sandbox
FINAPI_REDIRECT_URL=http://localhost:3000/api/finapi/callback

# -----------------------------------------------------------------------------
# Banking — Plaid
# -----------------------------------------------------------------------------
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENVIRONMENT=sandbox
# PLAID_REDIRECT_URL=http://localhost:3000/api/plaid/callback

# -----------------------------------------------------------------------------
# Email — Resend (transactional emails, budget warnings, digests)
# -----------------------------------------------------------------------------
# Set via Firebase secrets: firebase functions:secrets:set RESEND_API_KEY
# RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Email — Gmail Integration (OAuth for receipt scanning)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Encryption key for stored Gmail tokens (32-byte hex string)
# GMAIL_TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Observability — Langfuse (optional, for AI tracing)
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# FinanzOnline (Austrian tax filing — optional)
# -----------------------------------------------------------------------------
# FINANZONLINE_MODE=test

# -----------------------------------------------------------------------------
# Digest Emails
# -----------------------------------------------------------------------------
# HMAC secret for unsubscribe tokens
# DIGEST_HMAC_SECRET=

# -----------------------------------------------------------------------------
# Emulators (development only)
# -----------------------------------------------------------------------------
# Set to "false" to connect to production Firebase in development (NOT recommended)
# NEXT_PUBLIC_USE_EMULATORS=true
